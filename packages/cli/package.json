{
  "name": "@tripwire/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "bin": {
    "tripwire": "./bin/tripwire.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tripwire/daemon": "workspace:*",
    "@tripwire/feeds": "workspace:*",
    "@tripwire/shared": "workspace:*",
    "@tripwire/store": "workspace:*",
    "@tripwire/watcher": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
